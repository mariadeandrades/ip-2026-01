      "source": [
        "algoritmo_salario_energia\n",
        "\n",
        "declare salariomin, gastomen, conta, desconto numerico\n",
        "\n",
        "escreva (\"Qual o valor atual do salário mínimo?\")\n",
        "leia salariomin\n",
        "escreva (\"Qual o gasto de energia mensal da residência, em kW?\")\n",
        "leia gastomen\n",
        "\n",
        "funcao conta(salariomin, gastomen)\n",
        "    retorne (gastomen*11,347)\n",
        "\n",
        "funcao desconto(conta)\n",
        "    retorne(conta*0,9)\n",
        "\n",
        "fim_algoritmo_salario_energia"
      ],
      "metadata": {
        "id": "hh9Fcedob3HA"
      },
      "execution_count": null,
