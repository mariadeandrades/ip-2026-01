      "source": [
        "algoritmo_sequencia\n",
        "\n",
        "escreva (\"Digite dois números, sendo o primeiro par.\")\n",
        "receba n1 n2\n",
        "se n1 % 2 == 0:\n",
        "    para (i = n1; i <= n2; i+=2)\n",
        "        escreval (i, \" \")\n",
        "senao:\n",
        "    escreva (\"O número selecionado não é par.\")\n",
        "\n",
        "fim_algoritmo_sequencia"
