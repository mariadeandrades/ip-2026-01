    {
      "cell_type": "code",
      "source": [
        "algoritmo_quadrado_pares\n",
        "\n",
        "declare n, x numerico\n",
        "\n",
        "escreva (\"Qual é o número?\")\n",
        "receba n\n",
        "para (inteiro i = 0; i <= numero; i++) {\n",
        "    escreva (i, \" \")\n",
        "}\n",
        "se n % 2 == 0:\n",
        "    retorne (n^2) = x\n",
        "escreval (\"O quadrado do número é\", x \".\")\n",
        "senao\n",
        "    escreval (\"O número não é par.\")\n",
        "#tive bastante dificuldade pra fazer esse\n",
        "\n",
        "fim_algoritmo_quadrado_pares"
      ],
