        "algoritmo_area_piramide\n",
        "\n",
        "declare h, a float\n",
        "\n",
        "escreva (\"Digite a altura e a aresta da baseda pirâmide, em metros.\")\n",
        "receba h a\n",
        "funcao volume(h, a)\n",
        "    devolva ((a^2*3^1/2*h)/2)\n",
        "#usando raiz de três como três elevado a um sobre dois\n",
        "escreval (\"O volume da pirâmide é\", volume \"metros cúbicos.\")\n",
