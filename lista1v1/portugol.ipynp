    {
      "cell_type": "code",
      "source": [
        "algoritmo_composicao\n",
        "\n",
        "declare n1, n2, n3, x, y numerico\n",
        "\n",
        "escreva (\"Digite o primeiro número da composição, entre 1 e 9.\")\n",
        "leia n1\n",
        "se n1 = 0:\n",
        "    escreva (\"Número inválido.\")\n",
        "se n1 > 9:\n",
        "    escreva (\"Número inválido.\")\n",
        "\n",
        "escreva (\"Digite o segundo número da composição, entre 1 e 9.\")\n",
        "leia n2\n",
        "se n2 > 9:\n",
        "    escreva (\"Número inválido.\")\n",
        "\n",
        "escreva (\"Digite o terceiro número da composição, entre 1 e 9.\")\n",
        "leia n3\n",
        "se n3 > 9:\n",
        "    escreva (Número inválido.\")\n",
        "\n",
        "//usando a concatenação de números em portugol, feita por meio da vírgula entre os números a serem concatenados\n",
        "escreva (n1, n2, n3) = x\n",
        "x^2 = y\n",
        "escreva (\"O resultado da composição é\" x \",e o quadrado da composição é\" y.\")\n",
        "\n",
        "fim_algoritmo_composicao\n"
      ],
      "metadata": {
        "id": "7ilAKBQkXx1N"
      },
      "execution_count": null,
      "outputs": []
    },
