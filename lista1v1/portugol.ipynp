    {
      "cell_type": "code",
      "source": [
        "algoritmmo_soma\n",
        "\n",
        "escreva (\"Digite um número inteiro e positivo maior que 1.\")\n",
        "receba n1\n",
        "se n1 <= 0: {\n",
        "  pare\n",
        "    escreva (\"Número inválido.\")\n",
        "}\n",
        "senao {\n",
        "    para (k = 1; k <= n1; k++) {\n",
        "          soma = soma + (1/k)\n",
        "    }\n",
        "   escreval (\"A soma é\", soma \",\")\n",
        "}\n",
        "\n",
        "fim_algoritmo_soma"
      ],
      "metadata": {
        "id": "ecXxq_o8XGx1"
