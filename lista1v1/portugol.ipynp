      "source": [
        "algoritmo_progressao_aritmetica\n",
        "\n",
        "declare a1, r, n numerico\n",
        "\n",
        "escreva (\"Digite o primeiro termo da P.A., a sua razão e o seu número de termos.\")\n",
        "receba a1 r n\n",
        "para (i = a1; i <= n; i+=r) {\n",
        "    escreva (i, \" \")\n",
        "    soma = soma + i\n",
        "}\n",
        "\n",
        "fim_algoritmo_progressao_aritmetica"
