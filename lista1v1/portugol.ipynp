      }
    },
    {
      "cell_type": "code",
      "source": [
        "algoritmo_publico_futebol\n",
        "\n",
        "declare ptotal, ppopular, pgeral, parqui, pcadeiras, rendatotal, rp, rg, ra, rc numerico\n",
        "\n",
        "escreva (\"Qual o público total do jogo?\")\n",
        "leia ptotal\n",
        "escreva (\"Qual a porcentagem de público nas categorias popular, geral, arquibancada e cadeiras, respectivamente, em decimal?\")\n",
        "leia ppopular pgeral parqui pcadeiras\n",
        "funcao rp(ptotal, ppopular)\n",
        "    retorne(ptotal*ppopular*1)\n",
        "funcao rg(ptotal, pgeral)\n",
        "    retorne(ptotal*pgeral*5)\n",
        "funcao ra(ptotal*parqui*10)\n",
        "    retorne(ptotal*parqui*10)\n",
        "funcao rc(ptotal, pcadeiras)\n",
        "    retorne(ptotal*pcadeiras*20)\n",
        "\n",
        "rendatotal = (rp + rg + ra + rc)\n",
        "\n",
        "fim_algoritmo_publico_futebol"
      ],
      "metadata": {
        "id": "E1_5L3p4EHFd"
      },
      "execution_count": null,
      "outputs": []
    },
