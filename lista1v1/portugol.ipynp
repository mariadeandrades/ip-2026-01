    {
      "cell_type": "code",
      "source": [
        "algoritmo_conta_agua\n",
        "\n",
        "declare tipo, string\n",
        "declare consumo, conta numerico\n",
        "\n",
        "escreva (\"Qual tipo de conta é a sua?\")\n",
        "receba tipo\n",
        "escreva (\"Qual o seu consumo mensal de água, em litros?\")\n",
        "receba consumo\n",
        "\n",
        "se tipo == residencial:\n",
        "    entao conta = (5 + 0,5*consumo)\n",
        "se tipo == comercial:\n",
        "    entao conta =(500 + (consumo - 80)*0,25)\n",
        "senao\n",
        "    entao conta = (800 + (consumo - 100)*0,04)\n",
        "\n",
        "fim_algoritmo_conta_agua\n"
      ],
      "metadata": {
        "id": "v3bNAavOPZvu"
