    {
      "cell_type": "code",
      "source": [
        "algoritmo_delta\n",
        "\n",
        "declare a, b, c, D float\n",
        "\n",
        "escreva (\"Qual o valor do coeficiente a?\")\n",
        "receba a\n",
        "escreva (\"Qual o valor do coeficiente b?\")\n",
        "receba b\n",
        "escreva (\"Qual o valor do coeficiente c?\")\n",
        "receba c\n",
        "\n",
        "funcao D(a, b, c)\n",
        "    devolva(b^2 - 4*a*c)\n",
        "\n",
        "escreval (\"O valor de delta é\", D)\n",
        "\n",
        "fim_algoritmo_delta"
      ],
      "metadata": {
